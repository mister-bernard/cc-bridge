# cc-bridge runtime environment — copy to `.env` and fill in.
#
# All values below are loaded by the systemd unit (`deploy/cc-bridge.service`)
# at process start. The unit file itself is secret-free; this file is the
# only place secrets live.

# ─── Auth ─────────────────────────────────────────────────────────────────
# Bearer token clients must present on /v1/* requests. Generate one with
# `openssl rand -hex 32`. Anything is fine — it's a shared secret between
# this bridge and whatever gateway / bot calls it.
CC_BRIDGE_PROVIDER_KEY=

# ─── Listener ─────────────────────────────────────────────────────────────
BRIDGE_PORT=18901
BRIDGE_BIND=127.0.0.1
# Optional separate health-check port (defaults to BRIDGE_PORT).
# CC_BRIDGE_HEALTH_PORT=18790

# ─── Claude Code binary + model ───────────────────────────────────────────
# Path to your installed `claude` binary. Find with `which claude`.
CLAUDE_BIN=/usr/local/bin/claude
# Default model alias for spawned sessions. Per-session overrides via
# CC_BRIDGE_SESSION_MODELS below.
CC_BRIDGE_MODEL=sonnet
# Per-turn timeouts in milliseconds.
CC_BRIDGE_TURN_TIMEOUT_MS=480000
CC_BRIDGE_NO_PROGRESS_TIMEOUT_MS=300000

# IMPORTANT: leave ANTHROPIC_API_KEY EMPTY if Claude Code is signed in via
# OAuth (Max sub) — otherwise the API key takes precedence and you start
# getting billed per token. The systemd unit also enforces this.
# ANTHROPIC_API_KEY=

# ─── Sessions ─────────────────────────────────────────────────────────────
# Comma-separated list of session IDs the daemon advertises on /v1/models.
# (Any model string passed to /v1/chat/completions can lazy-spawn its own
# session — this list is for introspection only.)
CC_BRIDGE_SESSIONS=default

# Optional per-session model overrides (JSON: {sessionId: modelAlias}).
# CC_BRIDGE_SESSION_MODELS={"session-fast": "haiku"}

# Optional per-session idle timeout in ms (JSON: {sessionId: ms}).
# 0 = never expire. Sweeper checks every CC_BRIDGE_SWEEP_INTERVAL_MS.
# CC_BRIDGE_SESSION_IDLE_TIMEOUTS_MS={"default": 0, "session-cron": 600000}
# CC_BRIDGE_SWEEP_INTERVAL_MS=300000

# Optional per-session working directories (JSON: {sessionId: absolute path}).
# Each session inherits its own CWD; defaults to the daemon's CWD.
# CC_BRIDGE_SESSION_CWD={"session-foo": "/srv/cc-bridge/workspace-foo"}

# Optional per-session extra CLI args (JSON: {sessionId: ["--flag", ...]}).
# Useful for tool restrictions on public-facing sessions.
# CC_BRIDGE_SESSION_EXTRA_ARGS={"session-public": ["--allowed-tools", "Read,Grep,Glob"]}

# Optional stateless sessions (comma-separated). Skip shared-context +
# convo-log injection and skip writing turns to the convo log. Useful for
# fan-in sessions where many independent users share one session and the
# caller sends full per-thread context on every turn.
# CC_BRIDGE_SESSION_STATELESS=session-fanin

# Optional public-facing sessions (comma-separated). For each, the file
# `prompts/_common-public.txt` (if present) is prepended to the
# session-specific prompt. Centralizes group-channel framing.
# CC_BRIDGE_PUBLIC_SESSIONS=session-public

# ─── Outbound Telegram ────────────────────────────────────────────────────
# Required only if any session uses `bin/tg-send.sh` (e.g. for boot
# notifications or session-initiated alerts).
TELEGRAM_BOT_TOKEN=

# Default chat to send to when no `--chat` is passed. Usually the operator's
# Telegram user ID. Get yours by messaging @userinfobot.
CC_BRIDGE_TG_DEFAULT_CHAT=

# Path to the canonical sender that handles outbox-logging + origin
# registration (so user replies route back to this session). Typically
# the `tg-send-logged.sh` from your telegraph install. Fallback path is
# also probed if this is empty.
CC_BRIDGE_TG_SEND_CANONICAL=
# CC_BRIDGE_TG_SEND_FALLBACK=$HOME/scripts/tg-send-logged.sh

# Per-session group chats to notify on cold-start spawn (JSON: {sessionId:
# ["chat_id", ...]}). The bridge sends a "spinning up..." message to each
# chat and deletes it once the first real response is ready.
# CC_BRIDGE_SESSION_TG_GROUPS={"session-public": ["-1001234567890"]}

# Sessions that should NOT send the "spinning up" notification on cold
# start (comma-separated). For observer / silent agents.
# CC_BRIDGE_BOOT_NOTIFY_SUPPRESS=session-silent

# ─── Prompts ──────────────────────────────────────────────────────────────
# Optional override for prompt directory (default: ./prompts). Each session
# loads `<dir>/<session-id>.txt`, falling back to `<dir>/default.txt`.
# CC_BRIDGE_PROMPTS_DIR=

# Optional global system-prompt override. Wins over file-based prompts.
# Useful for single-session deploys.
# CC_BRIDGE_SYSTEM_PROMPT=
